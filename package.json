{
  "name": "ecotrade-backend",
  "version": "1.0.0",
  "description": "Backend para plataforma de economía circular EcoTrade",
  "main": "server-main.js",
  "scripts": {
    "postinstall": "prisma generate",
    "vercel-build": "node scripts/vercel-build.js",
    "start": "node server-main.js",
    "dev": "nodemon server-main.js",
    "frontend:install": "npm --prefix frontend install",
    "frontend:start": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "test": "jest",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:check": "node backend/scripts/dbCheck.js",
    "ecocoins:backfill-ledger": "node backend/scripts/backfillEcoCoinLedger.js",
    "bootstrap:superadmin": "node backend/scripts/bootstrapSuperAdmin.js",
    "backfill:companies": "node backend/scripts/backfillCompanies.js",
    "init-db": "node -e \"console.error('init-db está deshabilitado: era un script legacy (Mongo/Mongoose) y no aplica al stack actual Prisma/PostgreSQL. Usá prisma:migrate/db:push y bootstrap:superadmin.'); process.exit(1);\"",
    "reset-db": "node -e \"console.error('reset-db está deshabilitado: era un script legacy (Mongo/Mongoose) y no aplica al stack actual Prisma/PostgreSQL. Usá prisma:migrate/db:push y bootstrap:superadmin.'); process.exit(1);\""
  },
  "dependencies": {
    "@prisma/client": "^6.16.1",
    "@supabase/supabase-js": "^2.49.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^4.6.0",
    "joi": "^17.7.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "swagger-jsdoc": "^6.2.5",
    "swagger-ui-express": "^4.6.0"
  },
  "devDependencies": {
    "eslint": "^8.4.1",
    "jest": "^27.4.5",
    "nodemon": "^3.1.0",
    "prisma": "^6.16.1",
    "supertest": "^6.2.2"
  }
}
