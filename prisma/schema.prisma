generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  individual
  company
}

enum ProductStatus {
  available
  reserved
  sold
  paused
}

enum TransactionStatus {
  Pendiente
  Confirmada
  En_proceso
  Completada
  Cancelada
  Disputada
}

enum RecyclingPointStatus {
  active
  inactive
  suspended
}

enum VerificationStatus {
  pending
  approved
  partially_approved
  rejected
}

enum ReceiptStatus {
  none
  pending
  issued
  failed
}

enum CompanyStatus {
  active
  suspended
  closed
}

enum RecyclingPointOwnerType {
  platform
  company
}

enum EcoAccountOwnerType {
  user
  company
  platform
  escrow
}

enum EcoTxType {
  mint
  burn
  transfer
  purchase
  refund
  adjustment
}

enum EcoTxStatus {
  posted
  voided
}

model User {
  id                 String      @id @default(cuid())
  username           String      @unique
  email              String      @unique
  passwordHash       String
  accountType        AccountType @default(individual)
  country            String?
  recyclingCode      String      @unique
  profileImage       String?

  ecoCoins           Int         @default(0)
  totalTransactions  Int         @default(0)
  sustainabilityScore Int        @default(0)

  roles              String[]
  isActive           Boolean     @default(true)
  isVerified         Boolean     @default(false)

  location           Json?
  preferences        Json?
  rating             Json?
  verificationDocuments Json?

  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  products           Product[]   @relation("SellerProducts")
  purchases          Transaction[] @relation("BuyerTransactions")
  sales              Transaction[] @relation("SellerTransactions")

  administeredPoints RecyclingPoint[] @relation("PointAdmin")
  pointMemberships   RecyclingPointOperator[]
  verifiedSubmissions RecyclingSubmission[] @relation("VerifiedBy")
  recyclingSubmissions RecyclingSubmission[] @relation("UserSubmissions")
  registeredSubmissions RecyclingSubmission[] @relation("RegisteredBy")

  createdEcoTransactionsV2 EcoCoinTransactionV2[] @relation("EcoTxCreatedBy")

  ecoCoinLedgerEntries EcoCoinLedger[]

  companyMemberships  CompanyMember[]
}

model Company {
  id        String        @id @default(cuid())
  legalName String
  country   String?
  status    CompanyStatus @default(active)
  profile   Json?

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  members   CompanyMember[]
  products  Product[]
  points    RecyclingPoint[]

  @@index([status])
  @@index([country])
}

model CompanyMember {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  role      String   @default("member")
  status    String   @default("active")

  company   Company  @relation(fields: [companyId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([companyId, userId])
  @@index([userId])
  @@index([companyId])
}

model Product {
  id              String        @id @default(cuid())
  name            String
  description     String
  price           Float
  category        String
  condition       String
  status          ProductStatus @default(available)
  locationText    String?

  images          String[]
  tags            String[]

  ecologicalImpact Float?       @default(0)
  ecoCoinsGenerated Int         @default(0)
  estimatedCO2Saved Float?      @default(0)

  location        Json?
  specifications  Json?
  deliveryOptions Json?
  promotions      Json?

  sellerId        String?
  seller          User?         @relation("SellerProducts", fields: [sellerId], references: [id])

  // Multi-tenant (recomendado): el producto pertenece a una empresa.
  // Se deja opcional para compatibilidad con el modelo actual basado en sellerId.
  companyId       String?
  company         Company?      @relation(fields: [companyId], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  transactions    Transaction[]

  @@index([status])
  @@index([category])
  @@index([price])
  @@index([companyId])
}

model Transaction {
  id               String            @id @default(cuid())

  productId        String
  product          Product           @relation(fields: [productId], references: [id])

  buyerId          String
  buyer            User              @relation("BuyerTransactions", fields: [buyerId], references: [id])

  sellerId         String
  seller           User              @relation("SellerTransactions", fields: [sellerId], references: [id])

  amount           Float

  ecoCoinsBuyer    Int               @default(0)
  ecoCoinsSeller   Int               @default(0)
  ecoCoinsTotal    Int               @default(0)

  co2Saved         Float             @default(0)
  status           TransactionStatus @default(Pendiente)
  paymentMethod    String

  paymentDetails   Json?
  delivery         Json?
  timeline         Json?
  communication    Json?
  ratings          Json?
  metadata         Json?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  ecoCoinLedgerEntries EcoCoinLedger[]

  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([productId])
  @@index([createdAt])
}

model RecyclingPoint {
  id              String              @id @default(cuid())
  name            String
  description     String?
  address         String
  city            String
  state           String?
  country         String?

  status          RecyclingPointStatus @default(active)

  coordinates     Json?
  contactInfo     Json?
  operatingHours  Json?
  acceptedMaterials Json
  capacity        Json?
  features        Json?
  certifications  Json?
  stats           Json?

  // Ownership flexible (multi-tenant): punto puede ser de plataforma o de empresa.
  ownerType       RecyclingPointOwnerType @default(platform)
  companyId       String?
  company         Company?            @relation(fields: [companyId], references: [id])

  // Compatibilidad con el modelo actual (admin directo en User).
  administratorId String
  administrator   User                @relation("PointAdmin", fields: [administratorId], references: [id])

  operators       RecyclingPointOperator[]
  submissions     RecyclingSubmission[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([city])
  @@index([status])
  @@index([ownerType])
  @@index([companyId])
}

model RecyclingPointOperator {
  id        String         @id @default(cuid())
  pointId   String
  userId    String

  point     RecyclingPoint @relation(fields: [pointId], references: [id])
  user      User           @relation(fields: [userId], references: [id])

  createdAt DateTime       @default(now())

  @@unique([pointId, userId])
  @@index([userId])
}

model RecyclingSubmission {
  id                 String            @id @default(cuid())
  submissionCode     String            @unique

  userId             String
  user               User              @relation("UserSubmissions", fields: [userId], references: [id])

  recyclingPointId   String
  recyclingPoint     RecyclingPoint    @relation(fields: [recyclingPointId], references: [id])

  materials          Json
  submissionDetails  Json?

  // Trazabilidad (opcional, recomendado): quién registró la entrega (operador)
  registeredById     String?
  registeredBy       User?              @relation("RegisteredBy", fields: [registeredById], references: [id])

  // Idempotencia (opcional, recomendado): evita dobles registros por reintentos
  idempotencyKey     String?

  verificationStatus VerificationStatus @default(pending)
  verifiedById       String?
  verifiedBy         User?              @relation("VerifiedBy", fields: [verifiedById], references: [id])
  verificationDate   DateTime?
  verificationNotes  String?

  rewards            Json?
  tracking           Json?

  // TrustScore + evidencia verificable (proyecto personal)
  trustScore         Int?
  trustSignals       Json?
  trustAlgorithmVersion String?
  trustComputedAt    DateTime?
  evidenceHash       String?           @unique

  // Recibo verificable (Solana)
  receiptStatus      ReceiptStatus     @default(none)
  receiptIssuedAt    DateTime?
  receiptError       String?
  solanaCluster      String?
  solanaSignature    String?           @unique
  solanaExplorerUrl  String?

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  ecoCoinLedgerEntries EcoCoinLedger[]

  @@index([recyclingPointId, verificationStatus])
  @@index([userId])
  @@index([createdAt])
  @@index([registeredById])
  @@unique([recyclingPointId, idempotencyKey])
  @@index([receiptStatus])
}

model EcoCoinLedger {
  id                    String             @id @default(cuid())

  userId                String
  user                  User               @relation(fields: [userId], references: [id])

  delta                 Int
  reason                String

  transactionId         String?
  transaction           Transaction?       @relation(fields: [transactionId], references: [id])

  recyclingSubmissionId String?
  recyclingSubmission   RecyclingSubmission? @relation(fields: [recyclingSubmissionId], references: [id])

  metadata              Json?
  createdAt             DateTime           @default(now())

  @@index([userId, createdAt])
  @@index([transactionId])
  @@index([recyclingSubmissionId])

  @@unique([userId, reason, transactionId])
  @@unique([userId, reason, recyclingSubmissionId])
}

// Ledger contable v2 (recomendado para producción). Append-only mediante EcoCoinEntry.
// Se deja en paralelo para permitir migración gradual desde EcoCoinLedger.
model EcoCoinAccount {
  id        String             @id @default(cuid())
  ownerType EcoAccountOwnerType
  ownerId   String
  currency  String             @default("ECO")
  status    String             @default("active")
  metadata  Json?

  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  entries   EcoCoinEntry[]

  @@unique([ownerType, ownerId, currency])
  @@index([ownerType, ownerId])
}

model EcoCoinTransactionV2 {
  id            String       @id @default(cuid())
  type          EcoTxType
  status        EcoTxStatus  @default(posted)

  referenceType String?
  referenceId   String?

  idempotencyKey String?
  createdByUserId String?
  createdByUser   User?       @relation("EcoTxCreatedBy", fields: [createdByUserId], references: [id])

  metadata      Json?
  createdAt     DateTime     @default(now())

  entries       EcoCoinEntry[]

  @@index([type, createdAt])
  @@index([referenceType, referenceId])
  @@unique([idempotencyKey])
}

model EcoCoinEntry {
  id            String              @id @default(cuid())
  transactionId String
  accountId     String
  direction     String
  amount        Int
  metadata      Json?
  createdAt     DateTime            @default(now())

  transaction   EcoCoinTransactionV2 @relation(fields: [transactionId], references: [id])
  account       EcoCoinAccount      @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt])
  @@index([transactionId])
}
